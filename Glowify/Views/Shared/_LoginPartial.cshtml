@using Microsoft.AspNetCore.Identity
@using Glowify.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

@if (SignInManager.IsSignedIn(User))
{
    var user = await UserManager.GetUserAsync(User);

    <li class="nav-item">
        <a id="manage" class="nav-link text-dark fw-bold d-flex align-items-center gap-2" asp-area="Identity" asp-page="/Account/Manage/Index" title="Manage">
            <i class="bi bi-person-circle fs-5 text-primary"></i>
            Hello, @(user?.Name ?? User.Identity?.Name)!
        </a>
    </li>

    <li class="nav-item mt-2 mt-lg-0 ms-lg-2">
        <form id="logoutForm" class="form-inline m-0" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
            <button id="logout" type="submit" class="btn btn-outline-danger rounded-pill px-4 shadow-sm fw-medium d-flex align-items-center justify-content-center gap-2 w-100">
                <i class="bi bi-box-arrow-right"></i> Logout
            </button>
        </form>
    </li>
}
else
{
    <li class="nav-item mt-2 mt-lg-0">
        <a class="btn btn-outline-dark rounded-pill px-4 shadow-sm fw-medium d-flex align-items-center justify-content-center gap-2" id="login" asp-area="Identity" asp-page="/Account/Login">
            <i class="bi bi-box-arrow-in-right"></i> Login
        </a>
    </li>

    <li class="nav-item mt-2 mt-lg-0 ms-lg-2">
        <a class="btn btn-dark rounded-pill px-4 shadow-sm fw-medium d-flex align-items-center justify-content-center gap-2" id="register" asp-area="Identity" asp-page="/Account/Register">
            <i class="bi bi-person-plus"></i> Register
        </a>
    </li>
}