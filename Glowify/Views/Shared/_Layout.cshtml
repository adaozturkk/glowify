@using Glowify.Utility
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Glowify</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Glowify.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.3/font/bootstrap-icons.css">
    <link rel="stylesheet" href="//cdn.datatables.net/1.13.3/css/jquery.dataTables.min.css" />
</head>
<body class="bg-light">
    <div class="d-flex flex-column min-vh-100">
        <header>
            <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom shadow-sm sticky-top py-3 mb-4">
                <div class="container">
                    <a class="navbar-brand fw-bold fs-4 text-primary d-flex align-items-center gap-2" asp-area="" asp-controller="Home" asp-action="Index">
                        <i class="bi bi-stars"></i> Glowify
                    </a>

                    <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="offcanvas" data-bs-target="#offcanvasNavbar" aria-controls="offcanvasNavbar">
                        <i class="bi bi-list fs-1 text-dark"></i>
                    </button>

                    <div class="offcanvas offcanvas-end" tabindex="-1" id="offcanvasNavbar" aria-labelledby="offcanvasNavbarLabel">
                        <div class="offcanvas-header border-bottom px-4 py-3">
                            <h5 class="offcanvas-title fw-bold text-primary d-flex align-items-center gap-2" id="offcanvasNavbarLabel">
                                <i class="bi bi-stars"></i> Glowify
                            </h5>
                            <button type="button" class="btn-close shadow-none" data-bs-dismiss="offcanvas" aria-label="Close"></button>
                        </div>

                        <div class="offcanvas-body px-4 px-lg-0">
                            <ul class="navbar-nav flex-grow-1 align-items-lg-center gap-2">
                                <li class="nav-item">
                                    <a class="nav-link text-dark fw-medium d-flex align-items-center gap-2" asp-area="Customer" asp-controller="Home" asp-action="Index">
                                        <i class="bi bi-house-door"></i> Home
                                    </a>
                                </li>

                                @if (User.IsInRole(SD.Role_Admin) || User.IsInRole(SD.Role_Employee))
                                {
                                    <li class="nav-item dropdown">
                                        <a class="nav-link dropdown-toggle text-dark fw-medium d-flex align-items-center gap-2" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                            <i class="bi bi-shield-lock"></i> Management
                                        </a>
                                        <ul class="dropdown-menu border-0 shadow-lg mt-2">
                                            @if (User.IsInRole(SD.Role_Admin))
                                            {
                                                <li><a class="dropdown-item py-2" asp-area="Admin" asp-controller="Dashboard" asp-action="Index"><i class="bi bi-speedometer2 me-2"></i>Dashboard</a></li>
                                                <li><a class="dropdown-item py-2" asp-area="Admin" asp-controller="Coupon" asp-action="Index"><i class="bi bi-ticket-perforated me-2"></i>Coupons</a></li>
                                                <li><a class="dropdown-item py-2" asp-area="Admin" asp-controller="User" asp-action="Index"><i class="bi bi-people me-2"></i>User Management</a></li>
                                                <li><hr class="dropdown-divider"></li>
                                            }
                                            <li><a class="dropdown-item py-2" asp-area="Admin" asp-controller="Product" asp-action="Index"><i class="bi bi-box-seam me-2"></i>Products</a></li>
                                            <li><a class="dropdown-item py-2" asp-area="Admin" asp-controller="ProductReview" asp-action="Index"><i class="bi bi-star me-2"></i>Reviews</a></li>
                                            <li><a class="dropdown-item py-2" asp-area="Admin" asp-controller="Order" asp-action="Index"><i class="bi bi-receipt me-2"></i>Orders</a></li>
                                        </ul>
                                    </li>
                                }

                                @if (User.IsInRole(SD.Role_Customer))
                                {
                                    <li class="nav-item">
                                        <a class="nav-link text-dark fw-medium d-flex align-items-center gap-2" asp-area="Customer" asp-controller="Order" asp-action="Index">
                                            <i class="bi bi-bag-check"></i> My Orders
                                        </a>
                                    </li>
                                }

                                @if (User.Identity.IsAuthenticated)
                                {
                                    <li class="nav-item">
                                        <a class="nav-link text-dark fw-medium d-flex align-items-center gap-2" asp-area="Customer" asp-controller="Wishlist" asp-action="Index">
                                            <i class="bi bi-heart"></i> Wishlist
                                        </a>
                                    </li>
                                }
                            </ul>

                            <hr class="d-lg-none text-muted my-3">

                            <ul class="navbar-nav align-items-lg-center gap-3">
                                <li class="nav-item">
                                    @await Component.InvokeAsync("ShoppingCart")
                                </li>
                                <partial name="_LoginPartial" />
                            </ul>
                        </div>
                    </div>
                </div>
            </nav>
        </header>
    
        <main role="main" class="flex-grow-1 container pb-5">
            @RenderBody()
        </main>

        <footer class="bg-white border-top mt-auto py-4">
            <div class="container text-center text-muted small">
                <div class="mb-2">
                    <i class="bi bi-stars text-primary fs-5"></i>
                </div>
                <span class="fw-bold text-dark">&copy; 2026 Glowify</span> Skin Care. All rights reserved. <br />
                <a asp-area="" asp-controller="Home" asp-action="Privacy" class="text-decoration-none text-muted">Privacy Policy</a>
            </div>
        </footer>

    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="//cdn.datatables.net/1.13.3/js/jquery.dataTables.min.js"></script>
    <partial name="_Notification" />
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
