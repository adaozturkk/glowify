@page
@model ChangePasswordModel
@{
    ViewData["Title"] = "Change password";
    ViewData["ActivePage"] = ManageNavPages.ChangePassword;
}

<h4 class="fw-bold text-dark mb-4">
    <i class="bi bi-shield-lock-fill text-primary me-2"></i>@ViewData["Title"]
</h4>

<partial name="_StatusMessage" for="StatusMessage" />

<div class="row">
    <div class="col-md-11 col-lg-10">
        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-body p-4">
                <form id="change-password-form" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3" role="alert"></div>

                    <div class="form-floating mb-3">
                        <input asp-for="Input.OldPassword" class="form-control rounded-4 shadow-sm" autocomplete="current-password" aria-required="true" placeholder="Old Password" style="border: 1px solid #dee2e6;" />
                        <label asp-for="Input.OldPassword" class="text-muted">Old Password</label>
                        <span asp-validation-for="Input.OldPassword" class="text-danger small fw-medium"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-floating mb-3">
                                <input asp-for="Input.NewPassword" class="form-control rounded-4 shadow-sm" autocomplete="new-password" aria-required="true" placeholder="New Password" style="border: 1px solid #dee2e6;" />
                                <label asp-for="Input.NewPassword" class="text-muted">New Password</label>
                                <span asp-validation-for="Input.NewPassword" class="text-danger small fw-medium"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating mb-4">
                                <input asp-for="Input.ConfirmPassword" class="form-control rounded-4 shadow-sm" autocomplete="new-password" aria-required="true" placeholder="Confirm Password" style="border: 1px solid #dee2e6;" />
                                <label asp-for="Input.ConfirmPassword" class="text-muted">Confirm Password</label>
                                <span asp-validation-for="Input.ConfirmPassword" class="text-danger small fw-medium"></span>
                            </div>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-dark w-100 rounded-pill py-2 fw-bold shadow-sm d-flex justify-content-center align-items-center gap-2">
                        <i class="bi bi-key-fill"></i> Update Password
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}