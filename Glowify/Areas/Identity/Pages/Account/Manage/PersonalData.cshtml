@page
@model PersonalDataModel
@{
    ViewData["Title"] = "Personal Data";
    ViewData["ActivePage"] = ManageNavPages.PersonalData;
}

<h4 class="fw-bold text-dark mb-4">
    <i class="bi bi-file-earmark-person-fill text-primary me-2"></i>Data & Privacy
</h4>

<div class="row">
    <div class="col-md-11 col-lg-10">
        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-body p-4 p-md-5">

                <div class="mb-4">
                    <p class="text-muted">
                        Your account contains personal data that you have given us. This page allows you to securely download or permanently delete that data to maintain your privacy.
                    </p>
                </div>

                <div class="alert alert-danger rounded-4 shadow-sm d-flex align-items-start gap-3 mb-4">
                    <i class="bi bi-exclamation-triangle-fill fs-4"></i>
                    <div>
                        <h6 class="fw-bold mb-1">Danger Zone</h6>
                        <p class="mb-0 small">
                            <strong>Deleting this data will permanently remove your account, and this action cannot be undone or recovered.</strong>
                        </p>
                    </div>
                </div>

                <div class="d-flex flex-wrap gap-3 border-top pt-4">
                    <form id="download-data" asp-page="DownloadPersonalData" method="post" class="m-0">
                        <button class="btn btn-dark rounded-pill px-4 shadow-sm fw-medium d-flex align-items-center gap-2" type="submit">
                            <i class="bi bi-cloud-download"></i> Download My Data
                        </button>
                    </form>

                    <a id="delete" asp-page="DeletePersonalData" class="btn btn-outline-danger rounded-pill px-4 shadow-sm fw-medium d-flex align-items-center gap-2">
                        <i class="bi bi-trash3"></i> Delete Account
                    </a>
                </div>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}