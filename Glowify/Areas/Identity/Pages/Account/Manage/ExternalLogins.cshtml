@page
@model ExternalLoginsModel
@{
    ViewData["Title"] = "Manage your external logins";
    ViewData["ActivePage"] = ManageNavPages.ExternalLogins;
}

<h4 class="fw-bold text-dark mb-4">
    <i class="bi bi-globe text-primary me-2"></i>@ViewData["Title"]
</h4>

<partial name="_StatusMessage" for="StatusMessage" />

<div class="row">
    <div class="col-md-11 col-lg-10">
        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-body p-4">

                @if (Model.CurrentLogins?.Count > 0)
                {
                    <h6 class="fw-bold text-muted mb-3">Linked Accounts</h6>
                    <div class="d-flex flex-column gap-3 mb-4">
                        @foreach (var login in Model.CurrentLogins)
                        {
                            <div class="d-flex justify-content-between align-items-center p-3 border rounded-4 bg-light shadow-sm">
                                <div class="d-flex align-items-center gap-2 fw-medium text-dark" id="@($"login-provider-{login.LoginProvider}")">
                                    <i class="bi bi-@login.ProviderDisplayName.ToLower() fs-4 text-primary"></i>
                                    @login.ProviderDisplayName
                                </div>

                                <div>
                                    @if (Model.ShowRemoveButton)
                                    {
                                        <form id="@($"remove-login-{login.LoginProvider}")" asp-page-handler="RemoveLogin" method="post">
                                            <input asp-for="@login.LoginProvider" name="LoginProvider" type="hidden" />
                                            <input asp-for="@login.ProviderKey" name="ProviderKey" type="hidden" />
                                            <button type="submit" class="btn btn-outline-danger btn-sm rounded-pill px-3 shadow-sm d-flex align-items-center gap-1" title="Remove this @login.ProviderDisplayName login from your account">
                                                <i class="bi bi-trash3"></i> Remove
                                            </button>
                                        </form>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }

                @if (Model.OtherLogins?.Count > 0)
                {
                    <div class="mt-2 pt-4 border-top text-center">
                        <p class="small text-muted mb-3">Add another service to log in</p>
                        <form id="link-login-form" asp-page-handler="LinkLogin" method="post" class="form-horizontal">
                            <div id="socialLoginList" class="d-flex justify-content-center flex-wrap gap-2">
                                @foreach (var provider in Model.OtherLogins)
                                {
                                    <button id="@($"link-login-button-{provider.Name}")" type="submit" class="btn btn-outline-dark rounded-pill px-4 shadow-sm fw-medium d-flex align-items-center gap-2" name="provider" value="@provider.Name" title="Log in using your @provider.DisplayName account">
                                        <i class="bi bi-@provider.DisplayName.ToLower()"></i> Link @provider.DisplayName
                                    </button>
                                }
                            </div>
                        </form>
                    </div>
                }

            </div>
        </div>
    </div>
</div>