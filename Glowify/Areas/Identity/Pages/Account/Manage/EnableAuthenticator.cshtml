@page
@model EnableAuthenticatorModel
@{
    ViewData["Title"] = "Configure authenticator app";
    ViewData["ActivePage"] = ManageNavPages.TwoFactorAuthentication;
}

<partial name="_StatusMessage" for="StatusMessage" />

<h4 class="fw-bold text-dark mb-4">
    <i class="bi bi-qr-code-scan text-primary me-2"></i>Setup Authenticator App
</h4>

<div class="row">
    <div class="col-md-11 col-lg-10">
        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-body p-4 p-md-5">
                <p class="text-muted mb-4">To use an authenticator app, go through the following steps:</p>

                <ol class="list-group list-group-numbered list-group-flush mb-4">
                    
                    <li class="list-group-item border-0 px-0 pb-3 d-flex">
                        <div class="ms-2 me-auto">
                            <div class="fw-bold mb-1">Download an Authenticator App</div>
                            <span class="text-muted small">Download a two-factor authenticator app like Microsoft Authenticator for 
                                <a href="https://go.microsoft.com/fwlink/?Linkid=825072" target="_blank" class="text-decoration-none fw-medium">Android</a> and 
                                <a href="https://go.microsoft.com/fwlink/?Linkid=825073" target="_blank" class="text-decoration-none fw-medium">iOS</a> or Google Authenticator for 
                                <a href="https://play.google.com/store/apps/details?id=com.google.android.apps.authenticator2&amp;hl=en" target="_blank" class="text-decoration-none fw-medium">Android</a> and 
                                <a href="https://itunes.apple.com/us/app/google-authenticator/id388497605?mt=8" target="_blank" class="text-decoration-none fw-medium">iOS</a>.
                            </span>
                        </div>
                    </li>
                    
                    <li class="list-group-item border-0 px-0 py-3 d-flex">
                        <div class="ms-2 me-auto w-100">
                            <div class="fw-bold mb-2">Scan the QR Code</div>
                            <p class="text-muted small mb-3">Scan the QR Code below with your app, or manually enter this key: <kbd class="bg-dark px-2 rounded-2">@Model.SharedKey</kbd></p>
                            
                            <div class="text-center text-md-start">
                                <div id="qrCode" class="p-3 bg-white border rounded-4 d-inline-block shadow-sm"></div>
                            </div>
                            <div id="qrCodeData" data-url="@Html.Raw(Model.AuthenticatorUri)"></div>
                        </div>
                    </li>
                    
                    <li class="list-group-item border-0 px-0 pt-3 d-flex">
                        <div class="ms-2 me-auto w-100">
                            <div class="fw-bold mb-2">Verify Your Setup</div>
                            <p class="text-muted small mb-3">Once you have scanned the QR code, your app will provide you with a unique 6-digit code. Enter it below.</p>
                            
                            <div class="row">
                                <div class="col-md-8 col-lg-6">
                                    <form id="send-code" method="post">
                                        <div class="form-floating mb-3">
                                            <input asp-for="Input.Code" class="form-control rounded-4 shadow-sm" autocomplete="off" placeholder="123456" style="border: 1px solid #dee2e6;" />
                                            <label asp-for="Input.Code" class="text-muted">6-Digit Verification Code</label>
                                            <span asp-validation-for="Input.Code" class="text-danger small fw-medium"></span>
                                        </div>
                                        <button type="submit" class="btn btn-dark w-100 rounded-pill py-2 fw-bold shadow-sm d-flex justify-content-center align-items-center gap-2">
                                            <i class="bi bi-shield-check"></i> Verify & Enable 2FA
                                        </button>
                                        <div asp-validation-summary="ModelOnly" class="text-danger small mt-2" role="alert"></div>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </li>
                </ol>
                
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>

    <script type="text/javascript">
        document.addEventListener("DOMContentLoaded", function () {
            var qrCodeDataElement = document.getElementById("qrCodeData");
            if (qrCodeDataElement) {
                var uri = qrCodeDataElement.getAttribute('data-url');

                if (uri) {
                    new QRCode(document.getElementById("qrCode"), {
                        text: uri,
                        width: 150,
                        height: 150,
                        colorDark : "#212529",
                        colorLight : "#ffffff",
                        correctLevel : QRCode.CorrectLevel.H
                    });
                } else {
                    console.error("QR Code URI is empty or not found!");
                }
            }
        });
    </script>
}