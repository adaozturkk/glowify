@using Glowify.Models
@inject SignInManager<ApplicationUser> SignInManager
@{
    var hasExternalLogins = (await SignInManager.GetExternalAuthenticationSchemesAsync()).Any();
}

<div class="card border-0 shadow-sm rounded-4 mb-4">
    <div class="card-body p-3">
        <ul class="nav nav-pills flex-column gap-2">

            <li class="nav-item">
                <a class="nav-link rounded-pill d-flex align-items-center gap-2 fw-medium @ManageNavPages.IndexNavClass(ViewContext)" id="profile" asp-page="./Index">
                    <i class="bi bi-person-lines-fill fs-5"></i> Profile
                </a>
            </li>

            <li class="nav-item">
                <a class="nav-link rounded-pill d-flex align-items-center gap-2 fw-medium @ManageNavPages.EmailNavClass(ViewContext)" id="email" asp-page="./Email">
                    <i class="bi bi-envelope fs-5"></i> Email
                </a>
            </li>

            <li class="nav-item">
                <a class="nav-link rounded-pill d-flex align-items-center gap-2 fw-medium @ManageNavPages.ChangePasswordNavClass(ViewContext)" id="change-password" asp-page="./ChangePassword">
                    <i class="bi bi-key fs-5"></i> Password
                </a>
            </li>

            @if (hasExternalLogins)
            {
                <li id="external-logins" class="nav-item">
                    <a id="external-login" class="nav-link rounded-pill d-flex align-items-center gap-2 fw-medium @ManageNavPages.ExternalLoginsNavClass(ViewContext)" asp-page="./ExternalLogins">
                        <i class="bi bi-google fs-5"></i> External Logins
                    </a>
                </li>
            }

            <li class="nav-item mt-2 pt-2 border-top">
                <a class="nav-link rounded-pill d-flex align-items-center gap-2 fw-medium @ManageNavPages.TwoFactorAuthenticationNavClass(ViewContext)" id="two-factor" asp-page="./TwoFactorAuthentication">
                    <i class="bi bi-shield-check fs-5"></i> 2FA Security
                </a>
            </li>

            <li class="nav-item">
                <a class="nav-link rounded-pill d-flex align-items-center gap-2 fw-medium @ManageNavPages.PersonalDataNavClass(ViewContext)" id="personal-data" asp-page="./PersonalData">
                    <i class="bi bi-file-earmark-person fs-5"></i> Data & Privacy
                </a>
            </li>

        </ul>
    </div>
</div>