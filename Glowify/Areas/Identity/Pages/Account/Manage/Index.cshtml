@page
@model IndexModel
@{
    ViewData["Title"] = "Profile";
    ViewData["ActivePage"] = ManageNavPages.Index;
}

<h4 class="fw-bold text-dark mb-4">
    <i class="bi bi-person-lines-fill text-primary me-2"></i>@ViewData["Title"]
</h4>

<partial name="_StatusMessage" for="StatusMessage" />

<div class="row">
    <div class="col-md-11 col-lg-10">
        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-body p-4">
                <form id="profile-form" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3" role="alert"></div>

                    <div class="form-floating mb-4">
                        <input asp-for="Username" class="form-control rounded-4 bg-light text-muted" placeholder="Username" disabled style="border: 1px solid #dee2e6;" />
                        <label asp-for="Username" class="text-muted">Email (Username)</label>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-floating mb-3">
                                <input asp-for="Input.Name" class="form-control rounded-4 shadow-sm" placeholder="Full Name" style="border: 1px solid #dee2e6;" />
                                <label asp-for="Input.Name" class="text-muted">Full Name</label>
                                <span asp-validation-for="Input.Name" class="text-danger small fw-medium"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating mb-3">
                                <input asp-for="Input.PhoneNumber" class="form-control rounded-4 shadow-sm" placeholder="Phone Number" style="border: 1px solid #dee2e6;" />
                                <label asp-for="Input.PhoneNumber" class="text-muted">Phone Number</label>
                                <span asp-validation-for="Input.PhoneNumber" class="text-danger small fw-medium"></span>
                            </div>
                        </div>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Input.StreetAddress" class="form-control rounded-4 shadow-sm" placeholder="Street Address" style="border: 1px solid #dee2e6;" />
                        <label asp-for="Input.StreetAddress" class="text-muted">Street Address</label>
                        <span asp-validation-for="Input.StreetAddress" class="text-danger small fw-medium"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-4">
                            <div class="form-floating mb-3">
                                <input asp-for="Input.City" class="form-control rounded-4 shadow-sm" placeholder="City" style="border: 1px solid #dee2e6;" />
                                <label asp-for="Input.City" class="text-muted">City</label>
                                <span asp-validation-for="Input.City" class="text-danger small fw-medium"></span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-floating mb-3">
                                <input asp-for="Input.State" class="form-control rounded-4 shadow-sm" placeholder="State" style="border: 1px solid #dee2e6;" />
                                <label asp-for="Input.State" class="text-muted">State</label>
                                <span asp-validation-for="Input.State" class="text-danger small fw-medium"></span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-floating mb-4">
                                <input asp-for="Input.PostalCode" class="form-control rounded-4 shadow-sm" placeholder="Zip Code" style="border: 1px solid #dee2e6;" />
                                <label asp-for="Input.PostalCode" class="text-muted">Zip Code</label>
                                <span asp-validation-for="Input.PostalCode" class="text-danger small fw-medium"></span>
                            </div>
                        </div>
                    </div>

                    <button id="update-profile-button" type="submit" class="btn btn-dark w-100 rounded-pill py-2 fw-bold shadow-sm d-flex justify-content-center align-items-center gap-2">
                        <i class="bi bi-floppy"></i> Save Changes
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}