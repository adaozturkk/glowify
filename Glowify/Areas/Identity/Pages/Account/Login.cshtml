@page
@model LoginModel

@{
    ViewData["Title"] = "Log in";
}

<div class="row justify-content-center py-5">
    <div class="col-md-8 col-lg-5">
        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-body p-4 p-md-5">

                <div class="text-center mb-4">
                    <i class="bi bi-person-circle text-primary" style="font-size: 3rem;"></i>
                    <h3 class="fw-bold mt-2 text-dark">Welcome Back</h3>
                    <p class="text-muted small">Sign in to your Glowify account</p>
                </div>

                <form id="account" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3" role="alert"></div>

                    <div class="form-floating mb-3">
                        <input asp-for="Input.Email" class="form-control rounded-4 shadow-sm" autocomplete="username" aria-required="true" placeholder="name@example.com" style="border: 1px solid #dee2e6;" />
                        <label asp-for="Input.Email" class="form-label text-muted">Email address</label>
                        <span asp-validation-for="Input.Email" class="text-danger small fw-medium"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Input.Password" class="form-control rounded-4 shadow-sm" autocomplete="current-password" aria-required="true" placeholder="password" style="border: 1px solid #dee2e6;" />
                        <label asp-for="Input.Password" class="form-label text-muted">Password</label>
                        <span asp-validation-for="Input.Password" class="text-danger small fw-medium"></span>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <div class="form-check">
                            <input class="form-check-input shadow-sm" asp-for="Input.RememberMe" style="cursor:pointer;" />
                            <label asp-for="Input.RememberMe" class="form-check-label text-muted small" style="cursor:pointer;">
                                @Html.DisplayNameFor(m => m.Input.RememberMe)
                            </label>
                        </div>
                        <a id="forgot-password" asp-page="./ForgotPassword" class="text-decoration-none small text-primary fw-medium">Forgot password?</a>
                    </div>

                    <button id="login-submit" type="submit" class="btn btn-dark w-100 rounded-pill py-2 fw-bold mb-4 shadow-sm d-flex justify-content-center align-items-center gap-2">
                        <i class="bi bi-box-arrow-in-right"></i> Log In
                    </button>

                    <div class="text-center mt-4 pt-2">
                        <div class="mb-3 small text-muted">
                            Don't have an account?
                            <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="text-decoration-none text-primary fw-bold">Register here</a>
                        </div>

                        <div>
                            <a id="resend-confirmation" asp-page="./ResendEmailConfirmation" class="text-decoration-none text-secondary" style="font-size: 0.85rem;">
                                <i class="bi bi-envelope-exclamation"></i> Didn't receive confirmation email?
                            </a>
                        </div>
                    </div>
                </form>

                @{
                    if ((Model.ExternalLogins?.Count ?? 0) > 0)
                    {
                        <div class="mt-4 pt-4 border-top text-center">
                            <p class="small text-muted mb-3">Or log in with</p>
                            <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post" class="form-horizontal">
                                <div class="d-flex justify-content-center gap-2">
                                    @foreach (var provider in Model.ExternalLogins!)
                                    {
                                        <button type="submit" class="btn btn-outline-dark rounded-pill px-4 shadow-sm fw-medium d-flex align-items-center gap-2" name="provider" value="@provider.Name" title="Log in using your @provider.DisplayName account">
                                            <i class="bi bi-@provider.DisplayName.ToLower()"></i> @provider.DisplayName
                                        </button>
                                    }
                                </div>
                            </form>
                        </div>
                    }
                }

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}