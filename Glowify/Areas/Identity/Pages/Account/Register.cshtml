@page
@model RegisterModel
@{
    ViewData["Title"] = "Register";
}

<div class="row justify-content-center py-5">
    <div class="col-md-8 col-lg-6">
        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-body p-4 p-md-5">

                <div class="text-center mb-4">
                    <i class="bi bi-person-plus text-primary" style="font-size: 3rem;"></i>
                    <h3 class="fw-bold mt-2 text-dark">Create an Account</h3>
                    <p class="text-muted small">Join Glowify and start your skincare journey.</p>
                </div>

                <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3" role="alert"></div>

                    <div class="form-floating mb-3">
                        <input asp-for="Input.Name" class="form-control rounded-4 shadow-sm" placeholder="Full Name" style="border: 1px solid #dee2e6;" />
                        <label asp-for="Input.Name" class="text-muted">Full Name</label>
                        <span asp-validation-for="Input.Name" class="text-danger small fw-medium"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Input.Email" class="form-control rounded-4 shadow-sm" autocomplete="username" aria-required="true" placeholder="name@example.com" style="border: 1px solid #dee2e6;" />
                        <label asp-for="Input.Email" class="text-muted">Email address</label>
                        <span asp-validation-for="Input.Email" class="text-danger small fw-medium"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-floating mb-3">
                                <input asp-for="Input.Password" class="form-control rounded-4 shadow-sm" autocomplete="new-password" aria-required="true" placeholder="password" style="border: 1px solid #dee2e6;" />
                                <label asp-for="Input.Password" class="text-muted">Password</label>
                                <span asp-validation-for="Input.Password" class="text-danger small fw-medium"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating mb-3">
                                <input asp-for="Input.ConfirmPassword" class="form-control rounded-4 shadow-sm" autocomplete="new-password" aria-required="true" placeholder="password" style="border: 1px solid #dee2e6;" />
                                <label asp-for="Input.ConfirmPassword" class="text-muted">Confirm Password</label>
                                <span asp-validation-for="Input.ConfirmPassword" class="text-danger small fw-medium"></span>
                            </div>
                        </div>
                    </div>

                    <div class="form-floating mb-4">
                        <select asp-for="Input.Role" asp-items="@Model.Input.RoleList" class="form-select rounded-4 shadow-sm" style="border: 1px solid #dee2e6;">
                            <option disabled selected>- Select Role -</option>
                        </select>
                        <label asp-for="Input.Role" class="text-muted">Role</label>
                    </div>

                    <button id="registerSubmit" type="submit" class="btn btn-dark w-100 rounded-pill py-2 fw-bold mb-4 shadow-sm d-flex justify-content-center align-items-center gap-2">
                        <i class="bi bi-person-plus-fill"></i> Create Account
                    </button>

                    <div class="text-center small text-muted">
                        Already have an account?
                        <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl" class="text-decoration-none text-primary fw-bold">Log in here</a>
                    </div>
                </form>

                @{
                    if ((Model.ExternalLogins?.Count ?? 0) > 0)
                    {
                        <div class="mt-4 pt-4 border-top text-center">
                            <p class="small text-muted mb-3">Or register with</p>
                            <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post" class="form-horizontal">
                                <div class="d-flex justify-content-center gap-2">
                                    @foreach (var provider in Model.ExternalLogins!)
                                    {
                                        <button type="submit" class="btn btn-outline-dark rounded-pill px-4 shadow-sm fw-medium d-flex align-items-center gap-2" name="provider" value="@provider.Name" title="Log in using your @provider.DisplayName account">
                                            <i class="bi bi-@provider.DisplayName.ToLower()"></i> @provider.DisplayName
                                        </button>
                                    }
                                </div>
                            </form>
                        </div>
                    }
                }

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}