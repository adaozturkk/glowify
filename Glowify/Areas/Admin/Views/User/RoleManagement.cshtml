@model Glowify.Models.ApplicationUser

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-header bg-dark text-white rounded-top-4 py-3">
                    <h4 class="mb-0 fw-bold"><i class="bi bi-person-gear me-2"></i>Manage User Role</h4>
                </div>
                <div class="card-body p-4 p-md-5">

                    <form method="post">
                        <input asp-for="Id" type="hidden" />

                        <div class="mb-3">
                            <label class="form-label text-muted fw-bold">Email Address</label>
                            <input asp-for="Email" class="form-control rounded-3" readonly style="background-color: #f8f9fa;" />
                        </div>

                        <div class="mb-4">
                            <label class="form-label text-muted fw-bold">Select New Role</label>
                            <select asp-for="Role" asp-items="@ViewBag.RoleList" class="form-select rounded-3 border-secondary shadow-sm">
                            </select>
                        </div>

                        <div class="d-flex gap-3 mt-4">
                            <button type="submit" class="btn btn-primary rounded-pill fw-bold shadow-sm flex-grow-1 py-2">
                                <i class="bi bi-check2-circle me-2"></i> Update Role
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary rounded-pill fw-bold flex-grow-1 py-2 text-center">
                                Cancel
                            </a>
                        </div>
                    </form>

                </div>
            </div>
        </div>
    </div>
</div>