@model int

<div class="container mt-5 mb-5 d-flex justify-content-center">
	<div class="card border-0 shadow-sm text-center py-5 px-4 w-100" style="border-radius: 15px; max-width: 600px;">

		<div class="mb-4">
			<img src="~/images/success_order.png" class="img-fluid" style="max-width: 120px;" alt="Order Successful" />
		</div>

		<h2 class="fw-bold text-dark mb-3">Order Placed Successfully!</h2>

		<div class="bg-light rounded-pill d-inline-block px-4 py-2 mb-4 border shadow-sm mx-auto">
			<span class="text-secondary fw-bold text-uppercase small">Order Number:</span>
			<span class="fw-bolder text-dark ms-2 fs-5">#@Model</span>
		</div>

		<p class="text-muted mb-5 px-md-4">
			Thank you for your purchase! Your order has been placed successfully.<br />
			We will contact you via email shortly with your shipping details.
		</p>

		<div>
			<a asp-controller="Home" asp-action="Index" class="btn btn-dark rounded-pill px-5 py-3 fw-bold shadow-sm text-uppercase">
				Back to Home
			</a>
		</div>

	</div>
</div>