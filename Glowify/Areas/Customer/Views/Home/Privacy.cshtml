@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="row justify-content-center py-5">
    <div class="col-md-10 col-lg-8">

        <div class="text-center mb-4">
            <i class="bi bi-shield-check text-primary mb-2" style="font-size: 2.5rem;"></i>
            <h3 class="fw-bold text-dark">Privacy Policy</h3>
            <p class="text-muted small">Portfolio Project Disclaimer</p>
        </div>

        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-body p-4 p-md-5 text-muted">

                <p class="mb-4">
                    Welcome to <strong>Glowify</strong>. Please note that this website is a personal portfolio project created for demonstration purposes and is not an active commercial business.
                </p>

                <h6 class="fw-bold text-dark mb-2">1. Data Collection</h6>
                <p class="mb-4 small">
                    Any information you enter on this website (such as name, email, or address) is collected solely for the purpose of demonstrating the application's functionality. We strongly advise using dummy or test data when interacting with this platform.
                </p>

                <h6 class="fw-bold text-dark mb-2">2. Data Security</h6>
                <p class="mb-4 small">
                    While this is a test environment, standard security measures are in place to protect your login credentials. However, we do not use this data for real-world marketing or commercial purposes.
                </p>

                <h6 class="fw-bold text-dark mb-2">3. Your Rights</h6>
                <p class="mb-0 small">
                    You have full control over the test data you provide. You can delete your account and all associated data at any time directly from your <a asp-area="Identity" asp-page="/Account/Manage/PersonalData" class="text-decoration-none fw-bold text-primary">Account Settings</a>.
                </p>

            </div>
        </div>

    </div>
</div>